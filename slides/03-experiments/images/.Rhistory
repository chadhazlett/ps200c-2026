arrows(x0=-2,y0=mean(d$y_1),y1=mean(d$y_0),code=3,angle=45,lwd=2)
text(x=-2,y=mean(d$y_1)-(mean(d$y_1)-mean(d$y_0))/2,pos=2,label=c("ATE"))
arrows(x0=-1.75,y0=mean(d$y[d$treat==1]),y1=mean(d$y[d$treat==0]),code=3,angle=45,lwd=2)
text(x=-1.75,y=mean(d$y[d$treat==1])-(mean(d$y[d$treat==1])-mean(d$y[d$treat==0]))/2,pos=4,label=c("ATE_DiffMeans"))
# regression adjustment
mod1 <- lm(d$y[d$treat==1]~d$x[d$treat==1])
EY1reg <- mean(d$y[d$treat==1]) + coef(mod1)[2]*(mean(d$x)-mean(d$x[d$treat==1]))
abline(mod1,col="red",lwd=2)
abline(h=EY1reg,col="red",lty=3,lwd=3)
mod2 <- lm(d$y[d$treat==0]~d$x[d$treat==0])
EY0reg <- mean(d$y[d$treat==0]) + coef(mod2)[2]*(mean(d$x)-mean(d$x[d$treat==0]))
abline(mod2,col="blue",lwd=2)
abline(h=EY0reg,col="blue",lty=3,lwd=3)
arrows(x0=-1,y0=EY1reg,y1=EY0reg,code=3,angle=45,lwd=2)
text(x=-1,y=EY1reg-(EY1reg-EY0reg)/2,pos=4,label=c("ATE_RegInteract"))
abline(v=mean(d$x),col="darkgreen")
abline(v=mean(d$x[d$treat==1]),col="darkgreen",lty=2)
abline(v=mean(d$x[d$treat==0]),col="darkgreen",lty=2)
legend(legendpos,legend=c("Y_1","Y_0","Y|D=1","Y|D=0","E[Y_1]","E[Y_0]","E[X]","E[X|D=1]","E[X|D=0]","E[Y|D=1]_reg","E[Y|D=0]_reg"),
pch=c(0,1,15,19,NA,NA,NA,NA,NA,NA,NA),
lty=c(NA,NA,NA,NA,1,1,1,2,2,3,3),lwd=3,
col=c("red","blue","red","blue","red","blue","darkgreen","darkgreen","darkgreen","red","blue"),
cex=legendcex)
dev.off()
